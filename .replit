modules = ["nodejs-24", "javascript", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["pnpm", "run", "build"]
run = ["node", "artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MCP Server"

[[workflows.workflow]]
name = "MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mcp-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 45000

[nix]
channel = "stable-25_05"
packages = ["dig", "bash"]

[userenv]

[userenv.shared]
ACTIVITY_HMAC_SECRET = "REDACTED_ACTIVITY_HMAC_SECRET"
WEBHOOK_SECRET_KEY = "REDACTED_WEBHOOK_SECRET_KEY"
CREDENTIAL_SIGNING_SECRET = "REDACTED_CREDENTIAL_SIGNING_SECRET"
CLAIM_TOKEN_SECRET = "REDACTED_CLAIM_TOKEN_SECRET"
LAUNCH_MODE = "true"
STRIPE_MODE = "live"
X402_ENABLED = "true"
PLATFORM_TREASURY_ADDRESS = ""
APP_URL = "https://getagent.id"
VITE_WAITLIST_ENABLED = "false"
JWT_SECRET = "REDACTED_JWT_SECRET"
VC_SIGNING_KEY = """
-----BEGIN PRIVATE KEY-----
REDACTED_VC_SIGNING_KEY_BODY
-----END PRIVATE KEY-----
"""
VC_PUBLIC_KEY = """
-----BEGIN PUBLIC KEY-----
REDACTED_VC_PUBLIC_KEY_BODY
-----END PUBLIC KEY-----
"""
ADMIN_SECRET_KEY = "REDACTED_ADMIN_SECRET_KEY"
ADMIN_ALLOWED_IPS = "35.231.191.32"
TRUST_PROXY = "2"

[userenv.development]
STRIPE_PRICE_STARTER_MONTHLY = "price_1TEzHlRadiqNLsARtCw9BAWN"
STRIPE_PRICE_STARTER_YEARLY = "price_1TEzHlRadiqNLsAR4EWLofuW"
STRIPE_PRICE_PRO_MONTHLY = "price_1TEzHmRadiqNLsARrMYKV7vV"
STRIPE_PRICE_PRO_YEARLY = "price_1TEzHmRadiqNLsARpX76Ch9C"
STRIPE_PRICE_HANDLE_STANDARD = "price_1TEzHoRadiqNLsARpdxWkFih"
STRIPE_PRICE_HANDLE_PREMIUM = "price_1TEzHnRadiqNLsARKvqj4Aff"
STRIPE_PRICE_HANDLE_ELITE = "price_1TEzHnRadiqNLsARDYuSCpZQ"

[userenv.production]
STRIPE_PRICE_STARTER_MONTHLY = "price_1TEzQ10Qi9k0SFchgpmN2hNS"
STRIPE_PRICE_STARTER_YEARLY = "price_1TEzQ10Qi9k0SFch7BtgOvef"
