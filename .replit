modules = ["nodejs-24", "javascript", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["pnpm", "run", "build"]
run = ["node", "artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MCP Server"

[[workflows.workflow]]
name = "MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mcp-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"
packages = ["dig", "bash"]

[userenv]

[userenv.shared]
ACTIVITY_HMAC_SECRET = "0e04cbdf66d9bad6ba43d44a781feba07d8dde7aefb4e4d9a8f4e9b52b75480e"
WEBHOOK_SECRET_KEY = "53bb0908d0d399df940f5d47c7acd6da11f8a2a0933460799615ccf75d2067d9"
CREDENTIAL_SIGNING_SECRET = "882aea97c1fddb6537f25f79307038d5ac2792227b1652829f3c276573d12d96"
CLAIM_TOKEN_SECRET = "644909b572b06385603daa1c04cfeb760816208ebacd0afc653ef628d3cb7aa8167ecf298da7aee4beb2aa358e5cd987"
LAUNCH_MODE = "false"
STRIPE_MODE = "live"
APP_URL = "https://getagent.id"
