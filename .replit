modules = ["nodejs-24", "javascript", "python-3.11", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["pnpm", "run", "build"]
run = ["node", "artifacts/api-server/dist/index.cjs"]

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "MCP Server"

[[workflows.workflow]]
name = "MCP Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/mcp-server run dev"
waitForPort = 3001

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 45000

[nix]
channel = "stable-25_05"
packages = ["dig", "bash"]

[userenv]

[userenv.shared]
LAUNCH_MODE = "true"
STRIPE_MODE = "live"
X402_ENABLED = "true"
PLATFORM_TREASURY_ADDRESS = "0x261ab0e1019dBFdce07c819a257dca2f81e2D355"
