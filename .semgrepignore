# Replit platform infrastructure — managed by Replit, not user-authored code.
# [userenv.*] sections store environment variables set via the Replit Secrets UI.
# They are NOT hardcoded credentials; the scanner should not flag them.
.replit

# Generated build output
artifacts/*/dist/
lib/*/dist/
node_modules/

# Test fixtures and snapshots
**/__snapshots__/
**/*.test.ts
**/*.spec.ts

# Documentation and markdown files — contain illustrative placeholder env var names
# and example key prefixes (sk_live_..., whsec_...) that are NOT real credentials.
*.md
**/*.md

# Documentation pages in source — contain example API/key placeholders in code samples
artifacts/agent-id/src/pages/DocsPayments.tsx
artifacts/agent-id/src/pages/Protocol.tsx
artifacts/api-server/src/seo/

# Mockup sandbox — isolated UI prototypes, never shipped in production runtime.
artifacts/mockup-sandbox/src/components/mockups/

# Contract deployment manifest — contains on-chain contract addresses (not credentials).
contracts/deployment.json

# Scripts/tooling
scripts/
