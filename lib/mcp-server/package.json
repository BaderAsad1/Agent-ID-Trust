{
  "name": "@getagentid/mcp",
  "version": "1.0.0",
  "description": "MCP server for Agent ID — identity, trust, and task tools for AI agents",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "agentid-mcp": "bin/agentid-mcp.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-strip-types src/smoke-test.ts"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agent",
    "ai",
    "identity",
    "agent-id",
    "trust",
    "agentid"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentid/mcp"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
