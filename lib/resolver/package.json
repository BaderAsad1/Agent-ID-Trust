{
  "name": "@agentid/resolver",
  "version": "1.0.0",
  "description": "Open SDK for resolving .agent names to endpoints, capabilities, and trust scores",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agent",
    "ai",
    "resolver",
    "identity",
    "agent-protocol",
    "langchain",
    "crewai",
    "autogpt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentid/resolver"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
