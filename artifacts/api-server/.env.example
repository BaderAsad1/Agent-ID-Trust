# ============================================================================
# Agent ID API Server — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values for your environment.
# Variables marked [REQUIRED IN PRODUCTION] will cause the server to exit
# if missing when NODE_ENV=production.
# ============================================================================

# --- Core Server ---
PORT=3001                              # Server port (required)
NODE_ENV=development                   # "development" | "test" | "production"
DATABASE_URL=postgresql://user:pass@localhost:5432/agentid   # PostgreSQL connection string
DB_POOL_MAX=100                        # Maximum PostgreSQL connection pool size (default: 100)
REDIS_URL=redis://localhost:6379       # Redis for rate limiting + BullMQ workers
LOG_LEVEL=info                         # "debug" | "info" | "warn" | "error"

# --- Trust Proxy ---
# MUST be set for proxied deployments (Cloudflare, nginx, etc.).
# "false" = no proxy trust (default, secure for bare deployments)
# "1"     = trust first proxy
# "2"     = trust two proxies (e.g. Cloudflare + nginx)
# CIDR    = e.g. "103.21.244.0/22,103.22.200.0/22"
# WARNING: incorrect setting causes req.ip to show proxy IPs, breaking rate limits.
TRUST_PROXY=false                      # [REQUIRED IN PRODUCTION]

# --- CORS ---
# Comma-separated list of allowed origins for cross-origin requests.
# If unset in production, CORS is fail-closed: ALL cross-origin requests denied.
ALLOWED_ORIGINS=https://getagent.id,https://app.getagent.id  # [REQUIRED IN PRODUCTION]

# --- Security Secrets [REQUIRED IN PRODUCTION] ---
JWT_SECRET=your-jwt-secret-at-least-32-characters-long       # JWT signing (min 32 chars)
CLAIM_TOKEN_SECRET=your-claim-token-secret-here              # HMAC secret for claim token signing [REQUIRED IN PRODUCTION]
ADMIN_SECRET_KEY=your-admin-secret-key-here                  # Secret for /api/v1/admin/* routes (min 32 chars) [REQUIRED IN PRODUCTION]
ACTIVITY_HMAC_SECRET=your-hmac-secret-here                   # Activity log HMAC signing
WEBHOOK_SECRET_KEY=your-webhook-encryption-key               # Webhook payload encryption
CREDENTIAL_SIGNING_SECRET=your-credential-secret             # Internal credential HMAC
OAUTH_INTROSPECTION_SECRET=your-introspection-secret         # OAuth token introspection

# --- W3C Verifiable Credentials [REQUIRED IN PRODUCTION] ---
# Ed25519 JWK keys for signing/verifying W3C Verifiable Credentials.
# These power GET /api/.well-known/jwks.json (JWKS endpoint) and VC issuance.
# If absent in production, the server exits at startup (env.ts validateEnv guard).
# In dev/test, an ephemeral key pair is generated automatically (NOT for production).
#
# How to generate a key pair:
#   node --input-type=module << 'EOF'
#   import { generateKeyPair, exportJWK } from 'jose';
#   const { privateKey, publicKey } = await generateKeyPair('EdDSA', { crv: 'Ed25519' });
#   const priv = { ...(await exportJWK(privateKey)), kid: 'agentid-vc-key-1' };
#   const pub  = { ...(await exportJWK(publicKey)),  kid: 'agentid-vc-key-1' };
#   console.log('VC_SIGNING_KEY=' + JSON.stringify(priv));
#   console.log('VC_PUBLIC_KEY='  + JSON.stringify(pub));
#   EOF
#
# VC_SIGNING_KEY: Full private JWK (includes 'd' field), JSON-serialized as a single line
VC_SIGNING_KEY={"crv":"Ed25519","d":"...","x":"...","kty":"OKP","kid":"agentid-vc-key-1"}
# VC_PUBLIC_KEY: Public JWK only (no 'd' field), JSON-serialized as a single line
VC_PUBLIC_KEY={"crv":"Ed25519","x":"...","kty":"OKP","kid":"agentid-vc-key-1"}
VC_KEY_ID=agentid-vc-key-1            # Key identifier — must match 'kid' in both keys above

# --- URLs ---
APP_URL=https://getagent.id           # Base URL for the application
API_BASE_URL=https://getagent.id/api/v1   # Base URL for API endpoints
AUTH_BASE_URL=https://getagent.id     # Base URL for auth callbacks
BASE_AGENT_DOMAIN=getagent.id         # Root domain for agent handles
MAIL_BASE_DOMAIN=getagent.id          # Root domain for agent mail
COOKIE_DOMAIN=                        # Cookie domain for session cookies (optional, defaults to request host)

# --- OAuth / Social Login ---
GITHUB_CLIENT_ID=                      # GitHub OAuth App client ID
GITHUB_CLIENT_SECRET=                  # GitHub OAuth App client secret
GOOGLE_CLIENT_ID=                      # Google OAuth client ID
GOOGLE_CLIENT_SECRET=                  # Google OAuth client secret

# --- Stripe (Payments) ---
STRIPE_SECRET_KEY=sk_test_...         # Stripe secret key (alias: STRIPE_SK)
STRIPE_PUBLISHABLE_KEY=pk_test_...    # Stripe publishable key (alias: STRIPE_PK)
STRIPE_WEBHOOK_SECRET=whsec_...       # Stripe webhook signing secret (aliases: STRIPE_WH_SECRET, STRIPE_ENDPOINT_SECRET)
STRIPE_MODE=test                       # "test" | "live"

# Stripe price IDs for subscription plans
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# Stripe price IDs for handle tiers (3- and 4-char handles only; 5+ handles are included with plan)
STRIPE_PRICE_HANDLE_3CHAR_YEARLY=price_...   # $99/yr — ultra-premium 3-char handle
STRIPE_PRICE_HANDLE_4CHAR_YEARLY=price_...   # $29/yr — premium 4-char handle
# Note: 5+ char handles are included with Starter/Pro/Enterprise — no separate Stripe product needed

# --- Email (Resend) ---
RESEND_API_KEY=re_...                  # Resend API key for email delivery
FROM_EMAIL=notifications@getagent.id   # Default sender email address
RESEND_WEBHOOK_SECRET=                 # Resend webhook verification secret

# --- Cloudflare (Domain Management) ---
CLOUDFLARE_API_TOKEN=                  # Cloudflare API token
CLOUDFLARE_ZONE_ID=                    # Cloudflare zone ID for getagent.id

# --- Blockchain / Web3 ---
# Coinbase Developer Platform
CDP_API_KEY_ID=                        # CDP API key ID
CDP_API_KEY_SECRET=                    # CDP API key secret
CDP_WALLET_SECRET=                     # CDP wallet encryption secret
CDP_NETWORK_ID=base-mainnet           # CDP network (base-mainnet, base-sepolia)

# Base L2 — Contract Addresses
# Testnet (Base Sepolia, BASE_CHAIN_ID=84532):
#   Proxy (all write calls):   BASE_AGENTID_REGISTRAR=0x1D592A07dF4aFd897D25d348e90389C494034110
#   Registry (read reference): BASE_ERC8004_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
# Mainnet (Base, BASE_CHAIN_ID=8453):
#   Proxy:    BASE_AGENTID_REGISTRAR=<mainnet proxy address>
#   Registry: BASE_ERC8004_REGISTRY=0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
BASE_RPC_URL=                          # Base RPC endpoint (e.g. https://mainnet.base.org)
BASE_CHAIN_ID=8453                     # Chain ID: 8453 = Base mainnet, 84532 = Base Sepolia testnet
BASE_MINTER_PRIVATE_KEY=              # Private key for on-chain minting (0x-prefixed)
BASE_HANDLE_CONTRACT=                  # [Deprecated] Legacy handle NFT contract — no longer used at runtime
BASE_PLATFORM_WALLET=                  # Platform treasury wallet address
BASE_AGENTID_REGISTRAR=               # AgentIDRegistrar callable proxy — PRIMARY address for all write calls
BASE_ERC8004_REGISTRY=                # ERC-8004 registry address — kept as a separate named value for reference
BASE_METADATA_URI=                     # Base URI for on-chain NFT metadata (e.g. https://getagent.id/api/v1/nft/metadata/)
IS_TESTNET=false                       # Set to "true" to target Base Sepolia (shorthand; BASE_CHAIN_ID=84532 takes precedence)

# --- Handle Claim Tickets ---
# HMAC-signed one-time tickets issued at Stripe checkout time for /claim-nft.
HANDLE_CLAIM_SIGNING_PRIVATE_KEY=     # HMAC-SHA256 secret for claim-ticket signing [REQUIRED IN PRODUCTION]
HANDLE_CLAIM_ISSUER=agentid-api       # Issuer string embedded in claim tickets
HANDLE_CLAIM_MAX_AGE_SECONDS=300      # Ticket TTL in seconds (default: 5 minutes)

# Tron
TRON_API_URL=                          # Tron API endpoint
TRON_MINTER_PRIVATE_KEY=              # Tron minting private key
TRON_CONTRACT_ADDRESS=                 # Tron contract address
TRON_HANDLE_MINTED_TOPIC=             # Event topic for handle minting

# Platform
PLATFORM_TREASURY_ADDRESS=            # Platform treasury address
ONCHAIN_MINTING_ENABLED=false         # Enable on-chain handle minting (true/1 to enable)
MULTI_CHAIN_ENABLED=false             # Enable multi-chain support

# --- Feature Flags ---
LAUNCH_MODE=                           # Launch mode configuration
SANDBOX_MODE=disabled                  # "enabled" | "disabled"
X402_ENABLED=false                     # Enable X402 payment protocol

# --- Infrastructure ---
AGENT_PROXY_IP=127.0.0.1              # Internal agent proxy IP
ADMIN_ALLOWED_IPS=                     # Comma-separated admin IP whitelist

# --- Object Storage (R2 for mail attachments) ---
R2_ACCOUNT_ID=                         # Cloudflare account ID for R2
R2_ACCESS_KEY_ID=                      # R2 access key ID
R2_SECRET_ACCESS_KEY=                  # R2 secret access key
R2_BUCKET_NAME=                        # Bucket name for attachment uploads
R2_PUBLIC_URL=                         # Optional public/custom domain for attachment downloads

# --- Replit (auto-set in Replit environment) ---
# REPLIT_DEV_DOMAIN=                   # Set automatically by Replit
# REPL_ID=                             # Set automatically by Replit
