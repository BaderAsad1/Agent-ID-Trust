auto-install-peers=false
strict-peer-dependencies=false
# Platform-specific optional native binaries (e.g. @rollup/rollup-darwin-arm64) are treated
# as optional — failures installing them do not block the install or SDK build.
# The Agent ID SDK uses tsup/esbuild (not Rollup directly) so no native Rollup binary is
# required for `pnpm --filter @getagentid/sdk run build` to succeed.
ignore-optional-dev-deps=false
