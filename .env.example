# ================================================
# Agent ID — Environment Variables
# ================================================

# --- Database (auto-provisioned by Replit) ---
DATABASE_URL=postgresql://user:password@localhost:5432/agentid

# --- Redis (for BullMQ background jobs) ---
REDIS_URL=redis://localhost:6379

# --- Application URLs ---
APP_URL=https://your-app.replit.app
API_URL=https://your-app.replit.app/api
API_BASE_URL=https://your-app.replit.app/api/v1

# --- Agent Domain Provisioning ---
BASE_AGENT_DOMAIN=getagent.id

# --- Cloudflare DNS (for domain provisioning) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# --- Stripe (payments & subscriptions) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Resend (transactional email) ---
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# --- Mail ---
MAIL_BASE_DOMAIN=getagent.id

# --- Security ---
# All 5 secrets below are REQUIRED in production. The server will process.exit(1) if any are missing.
# Generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACTIVITY_HMAC_SECRET=your-activity-hmac-secret-min-32-chars
# Encryption-at-rest key for sensitive DB fields (agent keys, tokens).
# Must be stable across restarts — changing this makes all encrypted data unreadable.
WEBHOOK_SECRET_KEY=your-encryption-at-rest-key-min-32-chars
# JWT signing secret — minimum 32 characters.
JWT_SECRET=
# W3C Verifiable Credential Ed25519 signing key (base64-encoded private key).
VC_SIGNING_KEY=
# W3C Verifiable Credential Ed25519 public key (base64-encoded).
VC_PUBLIC_KEY=

# --- Credential Signing ---
# HMAC-SHA256 secret used to sign Agent ID credentials.
# Required in production. In development, an ephemeral secret is generated with a warning.
CREDENTIAL_SIGNING_SECRET=your-credential-signing-secret-min-32-chars

# --- Email ---
FROM_EMAIL=noreply@getagent.id

# --- Frontend (Vite) ---
VITE_API_BASE_URL=https://getagent.id/api/v1

# --- Payment Provider Toggles ---
PAYMENT_PROVIDER_STRIPE_ENABLED=true
PAYMENT_PROVIDER_COINBASE_ENABLED=false
PAYMENT_PROVIDER_VISA_ENABLED=false

# --- Coinbase Agentic Payments (future) ---
COINBASE_API_KEY=
COINBASE_WEBHOOK_SECRET=

# --- Visa Agentic Payments (future) ---
VISA_API_KEY=
VISA_WEBHOOK_SECRET=
