# ═══════════════════════════════════════════════════
#  AgentID Contracts — Environment Variables
#  Copy to .env and fill in your values
#  NEVER commit .env to git
# ═══════════════════════════════════════════════════

# Deployer wallet private key (without 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Basescan API key (get from basescan.org)
BASESCAN_API_KEY=

# RPC URLs (defaults work, override if using Alchemy/QuickNode)
BASE_SEPOLIA_RPC=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org

# ═══════════════════════════════════════════════════
#  Contract deployment config
#  Fill these in scripts/deploy.js before deploying
# ═══════════════════════════════════════════════════

# ERC-8004 IdentityRegistry addresses (already deployed by 8004 team)
# Testnet: 0x8004A818BFB912233c491871b3d84c89A494BD9e
# Mainnet: 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432

# Your minter wallet ADDRESS (not private key)
MINTER_ADDRESS=

# Your platform custody wallet ADDRESS
PLATFORM_WALLET_ADDRESS=

# ═══════════════════════════════════════════════════
#  After deployment — record these
# ═══════════════════════════════════════════════════

# Proxy address (this is your registrar address — never changes even after upgrades)
REGISTRAR_PROXY_ADDRESS=

# Implementation address (changes on each upgrade)
REGISTRAR_IMPL_ADDRESS=
